# Smart Job Placement - Environment Variables
# Copy this file to .env and fill in your values

# Backend API URL (REQUIRED)
# For Replit: VITE_API_URL=https://your-project-name.replit.app
# For local development: VITE_API_URL=http://localhost:10000
# For Render.com: VITE_API_URL=https://your-app-name.onrender.com
VITE_API_URL=

# GitHub Pages URL (optional, for CORS configuration)
# Format: https://your-username.github.io
GITHUB_PAGES_URL=
